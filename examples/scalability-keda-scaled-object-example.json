{
  "name": "kafka-consumer-scaler",
  "namespace": "production",
  "targetRef": {
    "apiVersion": "apps/v1",
    "kind": "Deployment",
    "name": "kafka-consumer"
  },
  "minReplicaCount": 0,
  "maxReplicaCount": 50,
  "pollingInterval": 30,
  "cooldownPeriod": 300,
  "triggers": [
    {
      "type": "kafka",
      "name": "kafka-order-events",
      "threshold": 100,
      "metadata": {
        "bootstrapServers": "kafka.production.svc.cluster.local:9092",
        "consumerGroup": "order-processors",
        "topic": "order-events",
        "lagThreshold": "100",
        "offsetResetPolicy": "latest"
      },
      "authenticationRef": {
        "name": "kafka-trigger-auth",
        "kind": "TriggerAuthentication"
      }
    }
  ],
  "scalingBehavior": {
    "scaleUp": {
      "stabilizationWindowSeconds": 0,
      "policies": [
        {
          "type": "Pods",
          "value": 10,
          "periodSeconds": 60
        }
      ],
      "selectPolicy": "Max"
    },
    "scaleDown": {
      "stabilizationWindowSeconds": 300,
      "policies": [
        {
          "type": "Percent",
          "value": 25,
          "periodSeconds": 60
        }
      ],
      "selectPolicy": "Min"
    }
  },
  "tags": {
    "team": "platform",
    "environment": "production",
    "app": "order-processor"
  }
}
