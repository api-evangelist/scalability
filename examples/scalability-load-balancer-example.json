    "healthyThreshold": 2,
    "unhealthyThreshold": 3,
    "expectedStatusCodes": [200]
  },
  "backends": [
    {
      "id": "backend-1",
      "address": "10.0.1.10",
      "port": 8080,
      "weight": 40,
      "status": "healthy"
    },
    {
      "id": "backend-2",
      "address": "10.0.1.11",
      "port": 8080,
      "weight": 40,
      "status": "healthy"
    },
    {
      "id": "backend-3",
      "address": "10.0.1.12",
      "port": 8080,
      "weight": 20,
      "status": "draining"
    }
  ],
  "stickySession": {
    "enabled": false
  },
  "tlsTermination": true,
  "tags": {
    "environment": "production",
    "team": "platform",
    "app": "api-gateway",
    "region": "us-east-1"
  }
